@prefix owl:  <http://www.w3.org/2002/07/owl#> .
@prefix rdf:  <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:  <http://www.w3.org/2001/XMLSchema#> .
@prefix self: <http://example.org/tax-classifier/self#> .
@prefix fin:  <http://example.org/financial/> .
@prefix tax:  <http://example.org/tax-classifier/> .
@prefix llm:  <http://example.org/llm#> .
@prefix fs:   <http://example.org/fs#> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix prov: <http://www.w3.org/ns/prov#> .

# ═══════════════════════════════════════════════════════════════════════════════
# Project registry — load this file first.
#
# Namespace mappings: read directly from the @prefix declarations above via
# g.namespaces().  No separate namespace-triple objects are needed.
#
# self:prefix on each ontology instance names which @prefix binding belongs
# to that ontology, so the loader can assemble the JSONLD_CONTEXT.
# ═══════════════════════════════════════════════════════════════════════════════

<http://example.org/tax-classifier/self> a owl:Ontology .

# ─── Schema ──────────────────────────────────────────────────────────────────

self:Self           a owl:Class .
self:Ontology       a owl:Class .
self:LocalOntology  a owl:Class ; rdfs:subClassOf self:Ontology .
self:RemoteOntology a owl:Class ; rdfs:subClassOf self:Ontology .

self:hasOntology  a owl:ObjectProperty  ; rdfs:domain self:Self      ; rdfs:range owl:Class .
self:targetClass  a owl:ObjectProperty  ; rdfs:domain self:Self      ; rdfs:range owl:Class .
self:prefix       a owl:DatatypeProperty ;                             rdfs:range xsd:string .
self:relativePath a owl:DatatypeProperty ;                             rdfs:range xsd:string .
self:url          a owl:ObjectProperty .

# ─── Self individual ──────────────────────────────────────────────────────────

self:this a self:Self, owl:NamedIndividual ;
    self:targetClass fin:FinancialDocument ;
    self:hasOntology self:financialDocs, self:models, self:shapes,
                     self:foaf, self:skos, self:prov .

# ─── Local ontologies ─────────────────────────────────────────────────────────

self:financialDocs a self:LocalOntology ;
    self:prefix       "fin" ;
    self:relativePath "data/financial_documents.ttl" .

self:models a self:LocalOntology ;
    self:prefix       "llm" ;
    self:relativePath "data/models.ttl" .

self:shapes a self:LocalOntology ;
    self:relativePath "data/shapes.ttl" .

# ─── Remote ontologies ────────────────────────────────────────────────────────

self:foaf a self:RemoteOntology ;
    self:prefix "foaf" ;
    self:url    <http://xmlns.com/foaf/0.1/> .

self:skos a self:RemoteOntology ;
    self:prefix "skos" ;
    self:url    <https://www.w3.org/2009/08/skos-reference/skos.rdf> .

self:prov a self:RemoteOntology ;
    self:prefix "prov" ;
    self:url    <http://www.w3.org/ns/prov-o> .

