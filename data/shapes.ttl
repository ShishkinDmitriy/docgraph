@prefix sh:   <http://www.w3.org/ns/shacl#> .
@prefix tax:  <http://example.org/tax-classifier/> .
@prefix fin:  <http://example.org/financial/> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix xsd:  <http://www.w3.org/2001/XMLSchema#> .

# ── Monetary amount shape ─────────────────────────────────────────────────────

tax:MonetaryAmountShape a sh:NodeShape ;
    sh:targetClass tax:MonetaryAmount ;
    sh:property [
        sh:path     tax:numericValue ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:datatype xsd:decimal ;
        sh:message  "tax:MonetaryAmount must have exactly one tax:numericValue (xsd:decimal)" ;
    ] ;
    sh:property [
        sh:path     tax:currency ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:datatype xsd:string ;
        sh:message  "tax:MonetaryAmount must have exactly one tax:currency (ISO 4217 string)" ;
    ] .

# ── FOAF agent shapes ─────────────────────────────────────────────────────────
# Every foaf:Person and foaf:Organization we mint must carry a foaf:name.

tax:PersonShape a sh:NodeShape ;
    sh:targetClass foaf:Person ;
    sh:property [
        sh:path     foaf:name ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:datatype xsd:string ;
        sh:message  "foaf:Person must have exactly one foaf:name string" ;
    ] .

tax:OrganizationShape a sh:NodeShape ;
    sh:targetClass foaf:Organization ;
    sh:property [
        sh:path     foaf:name ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:datatype xsd:string ;
        sh:message  "foaf:Organization must have exactly one foaf:name string" ;
    ] .

tax:AgentShape a sh:NodeShape ;
    sh:targetClass foaf:Agent ;
    sh:property [
        sh:path     foaf:name ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:datatype xsd:string ;
        sh:message  "foaf:Agent must have exactly one foaf:name string" ;
    ] .

# ── Provenance shape ──────────────────────────────────────────────────────────
# Targets every node that carries prov:wasGeneratedBy (i.e. classified docs).

tax:ClassifiedDocShape a sh:NodeShape ;
    sh:targetSubjectsOf prov:wasGeneratedBy ;
    sh:property [
        sh:path     prov:wasGeneratedBy ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:message  "Classified document must link to exactly one prov:Activity" ;
    ] ;
    sh:property [
        sh:path     prov:wasDerivedFrom ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:message  "Classified document must link to exactly one source file via prov:wasDerivedFrom" ;
    ] ;
    sh:property [
        sh:path     prov:wasAttributedTo ;
        sh:minCount 1 ;
        sh:message  "Classified document must be attributed to a model via prov:wasAttributedTo" ;
    ] ;
    sh:property [
        sh:path     tax:year ;
        sh:maxCount 1 ;
        sh:datatype xsd:gYear ;
        sh:message  "tax:year, if present, must be a single xsd:gYear value" ;
    ] .

# ── DemandForPayment shape ───────────────────────────────────────────────────

fin:DemandForPaymentShape a sh:NodeShape ;
    sh:targetClass fin:DemandForPayment ;
    sh:property [
        sh:path     fin:lineItem ;
        sh:minCount 1 ;
        sh:class    fin:LineItem ;
        sh:message  "DemandForPayment must have at least one fin:lineItem (fin:LineItem)" ;
    ] .

# ── W-2 shape ─────────────────────────────────────────────────────────────────

tax:W2FormShape a sh:NodeShape ;
    sh:targetClass tax:W2Form ;
    sh:property [
        sh:path     tax:employer ;
        sh:minCount 1 ;
        sh:class    foaf:Organization ;
        sh:message  "W-2 must have an employer (foaf:Organization)" ;
    ] ;
    sh:property [
        sh:path     tax:employee ;
        sh:minCount 1 ;
        sh:class    foaf:Person ;
        sh:message  "W-2 must have an employee (foaf:Person)" ;
    ] ;
    sh:property [
        sh:path     tax:wages ;
        sh:minCount 1 ;
        sh:class    tax:MonetaryAmount ;
        sh:message  "W-2 must have wages (tax:MonetaryAmount)" ;
    ] ;
    sh:property [
        sh:path     tax:ein ;
        sh:maxCount 1 ;
        sh:datatype xsd:string ;
        sh:message  "W-2 EIN must be a single string" ;
    ] .

# ── 1099-INT shape ────────────────────────────────────────────────────────────

tax:Form1099INTShape a sh:NodeShape ;
    sh:targetClass tax:Form1099INT ;
    sh:property [
        sh:path     tax:payer ;
        sh:minCount 1 ;
        sh:class    foaf:Organization ;
        sh:message  "1099-INT must have a payer (foaf:Organization)" ;
    ] ;
    sh:property [
        sh:path     tax:interestAmount ;
        sh:minCount 1 ;
        sh:class    tax:MonetaryAmount ;
        sh:message  "1099-INT must have an interest amount (tax:MonetaryAmount)" ;
    ] .

# ── 1099-NEC shape ────────────────────────────────────────────────────────────

tax:Form1099NECShape a sh:NodeShape ;
    sh:targetClass tax:Form1099NEC ;
    sh:property [
        sh:path     tax:payer ;
        sh:minCount 1 ;
        sh:class    foaf:Organization ;
        sh:message  "1099-NEC must have a payer (foaf:Organization)" ;
    ] ;
    sh:property [
        sh:path     tax:recipient ;
        sh:minCount 1 ;
        sh:class    foaf:Person ;
        sh:message  "1099-NEC must have a recipient (foaf:Person)" ;
    ] ;
    sh:property [
        sh:path     tax:compensationAmount ;
        sh:minCount 1 ;
        sh:class    tax:MonetaryAmount ;
        sh:message  "1099-NEC must have a compensation amount (tax:MonetaryAmount)" ;
    ] .

# ── Medical bill shape ────────────────────────────────────────────────────────

tax:MedicalBillShape a sh:NodeShape ;
    sh:targetClass tax:MedicalBill ;
    sh:property [
        sh:path     tax:provider ;
        sh:minCount 1 ;
        sh:class    foaf:Organization ;
        sh:message  "Medical bill must have a provider (foaf:Organization)" ;
    ] ;
    sh:property [
        sh:path     tax:patient ;
        sh:minCount 1 ;
        sh:class    foaf:Person ;
        sh:message  "Medical bill must have a patient (foaf:Person)" ;
    ] ;
    sh:property [
        sh:path     tax:patientOwes ;
        sh:maxCount 1 ;
        sh:class    tax:MonetaryAmount ;
        sh:message  "patientOwes, if present, must be a single tax:MonetaryAmount" ;
    ] .

# ── 1099-R shape ──────────────────────────────────────────────────────────────

tax:Form1099RShape a sh:NodeShape ;
    sh:targetClass tax:Form1099R ;
    sh:property [
        sh:path     tax:payer ;
        sh:minCount 1 ;
        sh:class    foaf:Organization ;
        sh:message  "1099-R must have a payer (foaf:Organization)" ;
    ] ;
    sh:property [
        sh:path     tax:grossDistribution ;
        sh:minCount 1 ;
        sh:class    tax:MonetaryAmount ;
        sh:message  "1099-R must have a gross distribution amount (tax:MonetaryAmount)" ;
    ] .

# ── Charitable donation shape ─────────────────────────────────────────────────

tax:CharitableDonationShape a sh:NodeShape ;
    sh:targetClass tax:CharitableDonation ;
    sh:property [
        sh:path     tax:organization ;
        sh:minCount 1 ;
        sh:class    foaf:Organization ;
        sh:message  "Charitable donation must name the organization (foaf:Organization)" ;
    ] ;
    sh:property [
        sh:path     tax:donationAmount ;
        sh:minCount 1 ;
        sh:class    tax:MonetaryAmount ;
        sh:message  "Charitable donation must have an amount (tax:MonetaryAmount)" ;
    ] .
