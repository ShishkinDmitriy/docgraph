@prefix sh:   <http://www.w3.org/ns/shacl#> .
@prefix tax:  <http://example.org/tax-classifier/> .
@prefix fin:  <http://example.org/financial/> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix xsd:  <http://www.w3.org/2001/XMLSchema#> .


# ── FOAF agent shapes ─────────────────────────────────────────────────────────
# Every foaf:Person and foaf:Organization we mint must carry a foaf:name.

tax:PersonShape a sh:NodeShape ;
    sh:targetClass foaf:Person ;
    sh:property [
        sh:path     foaf:name ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:datatype xsd:string ;
        sh:message  "foaf:Person must have exactly one foaf:name string" ;
    ] .

tax:OrganizationShape a sh:NodeShape ;
    sh:targetClass foaf:Organization ;
    sh:property [
        sh:path     foaf:name ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:datatype xsd:string ;
        sh:message  "foaf:Organization must have exactly one foaf:name string" ;
    ] .

tax:AgentShape a sh:NodeShape ;
    sh:targetClass foaf:Agent ;
    sh:property [
        sh:path     foaf:name ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:datatype xsd:string ;
        sh:message  "foaf:Agent must have exactly one foaf:name string" ;
    ] .

# ── Provenance shape ──────────────────────────────────────────────────────────
# Targets every node that carries prov:wasGeneratedBy (i.e. classified docs).

tax:ClassifiedDocShape a sh:NodeShape ;
    sh:targetSubjectsOf prov:wasGeneratedBy ;
    sh:property [
        sh:path     prov:wasGeneratedBy ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:message  "Classified document must link to exactly one prov:Activity" ;
    ] ;
    sh:property [
        sh:path     prov:wasDerivedFrom ;
        sh:minCount 1 ;
        sh:maxCount 1 ;
        sh:message  "Classified document must link to exactly one source file via prov:wasDerivedFrom" ;
    ] ;
    sh:property [
        sh:path     prov:wasAttributedTo ;
        sh:minCount 1 ;
        sh:message  "Classified document must be attributed to a model via prov:wasAttributedTo" ;
    ] ;
    sh:property [
        sh:path     tax:year ;
        sh:maxCount 1 ;
        sh:datatype xsd:gYear ;
        sh:message  "tax:year, if present, must be a single xsd:gYear value" ;
    ] .

# ── DemandForPayment shape ───────────────────────────────────────────────────

fin:DemandForPaymentShape a sh:NodeShape ;
    sh:targetClass fin:DemandForPayment ;
    sh:property [
        sh:path     fin:lineItem ;
        sh:minCount 1 ;
        sh:class    fin:LineItem ;
        sh:message  "DemandForPayment must have at least one fin:lineItem (fin:LineItem)" ;
    ] .

# ══════════════════════════════════════════════════════════════════════════════
# Extraction shapes
#
# These drive the shape_extractor pipeline (not validation).
# Each document class is linked to its extraction shape via tax:extractionShape.
# Depth is deliberately bounded by the DDD bounded-context rule:
#   - Value objects (LineItem, Service) → sh:node, fully extracted
#   - External entities (Agents)        → tax:AgentExtractionShape, identity only
#   - Cross-document refs               → omitted entirely
# ══════════════════════════════════════════════════════════════════════════════

# ── Shared: agent identity (used by all document shapes) ─────────────────────

tax:AgentExtractionShape a sh:NodeShape ;
    sh:property [ sh:path foaf:name    ; sh:maxCount 1 ; sh:datatype xsd:string ] ;
    sh:property [ sh:path foaf:address ; sh:maxCount 1 ; sh:datatype xsd:string ] .

# ── Shared: line item ─────────────────────────────────────────────────────────

fin:LineItemExtractionShape a sh:NodeShape ;
    tax:inline true ;
    sh:property [ sh:path fin:amount      ; sh:maxCount 1 ; sh:datatype xsd:decimal ] ;
    sh:property [ sh:path fin:quantity    ; sh:maxCount 1 ; sh:datatype xsd:decimal ] ;
    sh:property [ sh:path fin:unitPrice   ; sh:maxCount 1 ; sh:datatype xsd:decimal ] ;
    sh:property [ sh:path fin:currency    ; sh:maxCount 1 ; sh:datatype xsd:string  ] ;
    sh:property [ sh:path fin:taxAmount   ; sh:maxCount 1 ; sh:datatype xsd:decimal ] ;
    sh:property [ sh:path fin:serviceDate ; sh:maxCount 1 ; sh:datatype xsd:date    ] .

# ── ConfirmationOfPayment ─────────────────────────────────────────────────────

fin:ConfirmationOfPayment tax:extractionShape fin:ConfirmationOfPaymentExtractionShape .

fin:ConfirmationOfPaymentExtractionShape a sh:NodeShape ;
    sh:property [ sh:path fin:documentNumber    ; sh:maxCount 1 ; sh:datatype xsd:string  ] ;
    sh:property [ sh:path fin:issueDate         ; sh:maxCount 1 ; sh:datatype xsd:date    ] ;
    sh:property [ sh:path fin:totalAmount       ; sh:maxCount 1 ; sh:datatype xsd:decimal ] ;
    sh:property [ sh:path fin:currency          ; sh:maxCount 1 ; sh:datatype xsd:string  ] ;
    sh:property [ sh:path fin:notes             ; sh:maxCount 1 ; sh:datatype xsd:string  ] ;
    sh:property [ sh:path fin:issuer            ; sh:maxCount 1 ; sh:class foaf:Agent ;
                                                  sh:node tax:AgentExtractionShape        ] ;
    sh:property [ sh:path fin:documentRecipient ; sh:maxCount 1 ; sh:class foaf:Agent ;
                                                  sh:node tax:AgentExtractionShape        ] ;
    sh:property [ sh:path fin:lineItem          ; sh:class fin:LineItem ;
                                                  sh:node fin:LineItemExtractionShape     ] .

# ── DemandForPayment ──────────────────────────────────────────────────────────

fin:DemandForPayment tax:extractionShape fin:DemandForPaymentExtractionShape .

fin:DemandForPaymentExtractionShape a sh:NodeShape ;
    sh:property [ sh:path fin:documentNumber    ; sh:maxCount 1 ; sh:datatype xsd:string  ] ;
    sh:property [ sh:path fin:issueDate         ; sh:maxCount 1 ; sh:datatype xsd:date    ] ;
    sh:property [ sh:path fin:dueDate           ; sh:maxCount 1 ; sh:datatype xsd:date    ] ;
    sh:property [ sh:path fin:totalAmount       ; sh:maxCount 1 ; sh:datatype xsd:decimal ] ;
    sh:property [ sh:path fin:currency          ; sh:maxCount 1 ; sh:datatype xsd:string  ] ;
    sh:property [ sh:path fin:paymentTerms      ; sh:maxCount 1 ; sh:datatype xsd:string  ] ;
    sh:property [ sh:path fin:accountNumber     ; sh:maxCount 1 ; sh:datatype xsd:string  ] ;
    sh:property [ sh:path fin:notes             ; sh:maxCount 1 ; sh:datatype xsd:string  ] ;
    sh:property [ sh:path fin:issuer            ; sh:maxCount 1 ; sh:class foaf:Agent ;
                                                  sh:node tax:AgentExtractionShape        ] ;
    sh:property [ sh:path fin:documentRecipient ; sh:maxCount 1 ; sh:class foaf:Agent ;
                                                  sh:node tax:AgentExtractionShape        ] ;
    sh:property [ sh:path fin:lineItem          ; sh:class fin:LineItem ;
                                                  sh:node fin:LineItemExtractionShape     ] .

# ── Quote ─────────────────────────────────────────────────────────────────────

fin:Quote tax:extractionShape fin:QuoteExtractionShape .

fin:QuoteExtractionShape a sh:NodeShape ;
    sh:property [ sh:path fin:documentNumber    ; sh:maxCount 1 ; sh:datatype xsd:string  ] ;
    sh:property [ sh:path fin:issueDate         ; sh:maxCount 1 ; sh:datatype xsd:date    ] ;
    sh:property [ sh:path fin:quoteExpiryDate   ; sh:maxCount 1 ; sh:datatype xsd:date    ] ;
    sh:property [ sh:path fin:totalAmount       ; sh:maxCount 1 ; sh:datatype xsd:decimal ] ;
    sh:property [ sh:path fin:currency          ; sh:maxCount 1 ; sh:datatype xsd:string  ] ;
    sh:property [ sh:path fin:paymentTerms      ; sh:maxCount 1 ; sh:datatype xsd:string  ] ;
    sh:property [ sh:path fin:notes             ; sh:maxCount 1 ; sh:datatype xsd:string  ] ;
    sh:property [ sh:path fin:issuer            ; sh:maxCount 1 ; sh:class foaf:Agent ;
                                                  sh:node tax:AgentExtractionShape        ] ;
    sh:property [ sh:path fin:documentRecipient ; sh:maxCount 1 ; sh:class foaf:Agent ;
                                                  sh:node tax:AgentExtractionShape        ] ;
    sh:property [ sh:path fin:lineItem          ; sh:class fin:LineItem ;
                                                  sh:node fin:LineItemExtractionShape     ] .

# ── Statement ─────────────────────────────────────────────────────────────────

fin:Statement tax:extractionShape fin:StatementExtractionShape .

fin:StatementExtractionShape a sh:NodeShape ;
    sh:property [ sh:path fin:documentNumber        ; sh:maxCount 1 ; sh:datatype xsd:string  ] ;
    sh:property [ sh:path fin:issueDate             ; sh:maxCount 1 ; sh:datatype xsd:date    ] ;
    sh:property [ sh:path fin:statementPeriodStart  ; sh:maxCount 1 ; sh:datatype xsd:date    ] ;
    sh:property [ sh:path fin:statementPeriodEnd    ; sh:maxCount 1 ; sh:datatype xsd:date    ] ;
    sh:property [ sh:path fin:openingBalance        ; sh:maxCount 1 ; sh:datatype xsd:decimal ] ;
    sh:property [ sh:path fin:closingBalance        ; sh:maxCount 1 ; sh:datatype xsd:decimal ] ;
    sh:property [ sh:path fin:minimumPaymentDue     ; sh:maxCount 1 ; sh:datatype xsd:decimal ] ;
    sh:property [ sh:path fin:currency              ; sh:maxCount 1 ; sh:datatype xsd:string  ] ;
    sh:property [ sh:path fin:accountNumber         ; sh:maxCount 1 ; sh:datatype xsd:string  ] ;
    sh:property [ sh:path fin:issuer                ; sh:maxCount 1 ; sh:class foaf:Agent ;
                                                      sh:node tax:AgentExtractionShape        ] ;
    sh:property [ sh:path fin:documentRecipient     ; sh:maxCount 1 ; sh:class foaf:Agent ;
                                                      sh:node tax:AgentExtractionShape        ] .

# ── Payout ────────────────────────────────────────────────────────────────────

fin:Payout tax:extractionShape fin:PayoutExtractionShape .

fin:PayoutExtractionShape a sh:NodeShape ;
    sh:property [ sh:path fin:payoutReference   ; sh:maxCount 1 ; sh:datatype xsd:string  ] ;
    sh:property [ sh:path fin:payoutDate        ; sh:maxCount 1 ; sh:datatype xsd:date    ] ;
    sh:property [ sh:path fin:grossPayoutAmount ; sh:maxCount 1 ; sh:datatype xsd:decimal ] ;
    sh:property [ sh:path fin:deductionsAmount  ; sh:maxCount 1 ; sh:datatype xsd:decimal ] ;
    sh:property [ sh:path fin:netPayoutAmount   ; sh:maxCount 1 ; sh:datatype xsd:decimal ] ;
    sh:property [ sh:path fin:payoutMethod      ; sh:maxCount 1 ; sh:datatype xsd:string  ] ;
    sh:property [ sh:path fin:payoutStatus      ; sh:maxCount 1 ; sh:datatype xsd:string  ] ;
    sh:property [ sh:path fin:payoutPeriodStart ; sh:maxCount 1 ; sh:datatype xsd:date    ] ;
    sh:property [ sh:path fin:payoutPeriodEnd   ; sh:maxCount 1 ; sh:datatype xsd:date    ] ;
    sh:property [ sh:path fin:payoutIssuer      ; sh:maxCount 1 ; sh:class foaf:Organization ;
                                                  sh:node tax:AgentExtractionShape        ] ;
    sh:property [ sh:path fin:payoutRecipient   ; sh:maxCount 1 ; sh:class foaf:Agent ;
                                                  sh:node tax:AgentExtractionShape        ] .
