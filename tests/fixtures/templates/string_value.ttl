# Leaf value-wrapper template — wraps an xsd:string literal in a Part 2-shaped
# representation cluster. Used via invocation by higher-level templates that
# want a typed value rather than a bare literal.
@prefix tpl:      <http://example.org/docgraph/template#> .
@prefix iso15926: <http://rds.posccaesar.org/2008/02/OWL/ISO-15926-2_2003#> .
@prefix var:      <urn:tpl-var/> .
@prefix xsd:      <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs:     <http://www.w3.org/2000/01/rdf-schema#> .

tpl:StringValue a tpl:Template ;
    rdfs:label "String value (wrapped in a Part 2 representation cluster)" ;
    tpl:definition "[literal] is the string value of [this]." ;
    tpl:subject iso15926:ClassOfInformationRepresentation ;
    tpl:slot var:literal ;
    tpl:lowered var:lowered .

var:literal tpl:range xsd:string .

GRAPH var:lowered {
    var:this a iso15926:ClassOfInformationRepresentation ;
             iso15926:hasLiteral var:literal .
}
