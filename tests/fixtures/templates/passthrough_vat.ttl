# Pass-through, instance-form template — single-triple lowered body identical
# to the auto-derived lifted form (the degenerate case described in
# ARCHITECTURE.md > "The reification spectrum").
@prefix tpl:  <http://example.org/docgraph/template#> .
@prefix dom:  <http://example.org/docgraph/financial#> .
@prefix var:  <urn:tpl-var/> .
@prefix xsd:  <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

dom:InvoiceHasVatNumber a tpl:Template ;
    rdfs:label  "Invoice has VAT number" ;
    tpl:definition "[invoice] has VAT identifier [value]." ;
    tpl:slot var:invoice, var:value ;
    tpl:lowered var:lowered .

var:invoice tpl:range dom:Invoice .
var:value   tpl:range xsd:string .

GRAPH var:lowered {
    var:invoice dom:hasVatNumber var:value .
}
